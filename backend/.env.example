# ═══════════════════════════════════════════════════════════════════════════════
# Jatham Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY: Never commit the actual .env file to source control.
# Copy this file to .env and fill in real values.
# Rotate all secrets before deploying to production.

# ─── Environment ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/jatham

# MongoDB CSFLE — must be exactly 96 bytes Base64-encoded (64 bytes raw)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
MONGODB_ENCRYPTION_KEY=

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# SECURITY: Must be at least 64 random bytes each. NEVER reuse between access/refresh.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX

# ─── Frontend URL (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Twilio (OTP SMS) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Anthropic (AI Reports) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# ─── Cloudinary (Photo Upload) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── OpenCage (Geocoding) ────────────────────────────────────────────────────
OPENCAGE_API_KEY=

# ─── Redis (Bull Queue) ──────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# Frontend Environment Variables
# Copy to .env.local for local development
# Set these as Environment Variables in Vercel dashboard for production

# ─── API ──────────────────────────────────────────────────────────────────────
# Local dev (uses Vite proxy to localhost:5000 — see vite.config.js)
VITE_API_URL=

# Production (set to your Railway backend URL)
# VITE_API_URL=https://api.jatham.app/api

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Jatham
VITE_APP_VERSION=1.0.0
